{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/live",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/cron/live-corners",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/finalize",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
