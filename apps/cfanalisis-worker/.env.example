# ── HTTP server (recibe webhooks de Vercel) ───────────────────
PORT=8080
WORKER_SECRET=change-me-shared-secret-with-vercel

# ── BullMQ Redis (local del VPS) ──────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Upstash Redis (cache de app: fixtures, live, analysis) ────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API providers ─────────────────────────────────────────────
FOOTBALL_API_KEY=
BZZOIRO_API_KEY=
THE_ODDS_API_KEY=

# ── Pusher (realtime push a dashboards) ───────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Web Push (notificaciones a navegadores) ───────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Misc ──────────────────────────────────────────────────────
ADMIN_EMAIL=
CRON_SECRET=
NODE_ENV=production
