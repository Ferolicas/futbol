# ── HTTP server (recibe webhooks de Vercel) ───────────────────
PORT=8080
WORKER_SECRET=change-me-shared-secret-with-vercel

# ── BullMQ Redis (local del VPS) ──────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Upstash Redis (cache de app: fixtures, live, analysis) ────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API providers ─────────────────────────────────────────────
FOOTBALL_API_KEY=
BZZOIRO_API_KEY=
THE_ODDS_API_KEY=

# ── Pusher (DEPRECATED) — el realtime ahora va por WebSocket nativo ─────
# Ya no se usan; el worker hace broadcast directo via /ws con wsManager.
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=

# ── PostgreSQL VPS (todas las tablas de datos) ───────────────────────────
# Antes 5432 directo; tras instalar PgBouncer cambiar a 6432 (pool transaction).
DATABASE_URL=postgresql://cfanalisis:PASSWORD@127.0.0.1:6432/cfanalisis
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# ── Logging (Pino) ───────────────────────────────────────────────────────
# Pino escribe siempre a stdout (capturado por PM2). Si LOG_FILE esta seteado,
# tambien escribe a ese path en JSON estructurado. Rotacion via logrotate
# del sistema (ver INSTALL.md → "Bloque 4 — Pino + Telegram alerts").
LOG_LEVEL=info
LOG_FILE=/var/log/cfanalisis/worker.log

# ── Alertas Telegram en errores ──────────────────────────────────────────
# El worker manda 1 alerta/min (dedup) cuando falla un job BullMQ, un
# handler de Fastify o el proceso (uncaughtException/unhandledRejection).
# CHAT_ID = usuario personal (no el canal de status publico). Sin estas
# vars, las alertas estan desactivadas pero los errores siguen logueandose.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── Web Push (notificaciones a navegadores) ───────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Misc ──────────────────────────────────────────────────────
ADMIN_EMAIL=
CRON_SECRET=
NODE_ENV=production
