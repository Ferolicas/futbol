# /apps/scripts/health.env — credenciales del health_check.sh
# chmod 600 cuando lo copies al VPS.

# URL del endpoint /health en el worker (Caddy via 443).
HEALTH_URL=https://worker.cfanalisis.com/health

# Bot Telegram @cfanalisis_bot — chat ID del grupo de alertas
TELEGRAM_BOT_TOKEN=<<CAMBIAR>>
TELEGRAM_CHAT_ID=<<CAMBIAR>>
