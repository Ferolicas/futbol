# /apps/backup/.env — credenciales del script de backup
# NO commitear este archivo con valores reales. Copia a /apps/backup/.env
# y rellena. chmod 600 para que solo root lo lea.

# ── Acceso a PostgreSQL local ────────────────────────────────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=cfanalisis
PGPASSWORD=<<CAMBIAR>>
PGDATABASE=cfanalisis

# ── Destino remoto en Backblaze B2 (vía rclone) ──────────────────────────
# Tras configurar rclone con `rclone config` y crear el remote "b2":
#   rclone config
#   → n) New remote → name "b2" → type "Backblaze B2"
#   → introduce Application Key ID y Application Key (NO la master key)
#   → crear bucket "cfanalisis-backups" en https://secure.backblaze.com/
RCLONE_REMOTE=b2:cfanalisis-backups/pg

# ── Alerta Telegram (mismo bot que health_check.sh) ──────────────────────
# Bot: @cfanalisis_bot — chat ID del grupo de alertas
TELEGRAM_BOT_TOKEN=<<CAMBIAR>>
TELEGRAM_CHAT_ID=<<CAMBIAR>>
