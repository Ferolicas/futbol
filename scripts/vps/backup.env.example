# /apps/backup/.env — credenciales del script de backup
# NO commitear este archivo con valores reales. Copia a /apps/backup/.env
# y rellena. chmod 600 para que solo root lo lea.

# ── Acceso a PostgreSQL local ────────────────────────────────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=cfanalisis
PGPASSWORD=<<CAMBIAR>>
PGDATABASE=cfanalisis

# ── Destino remoto en Google Drive (vía rclone) ──────────────────────────
# Pasos detallados de configuracion en scripts/vps/INSTALL.md (sección
# "Bloque 1 — Backups"). Resumen:
#   1. Crear (a mano, en drive.google.com) una carpeta llamada
#      "cfanalisis-backups" en la raiz de tu Google Drive.
#   2. rclone config en el VPS → nuevo remote "gdrive" tipo "drive".
#   3. Autenticar via OAuth en el navegador de tu portatil
#      (rclone authorize "drive") y pegar el token al VPS.
#   4. Una vez configurado: rclone lsd gdrive: → debe mostrar la carpeta.
#
# Formato: <nombre-del-remote>:<carpeta>
RCLONE_REMOTE=gdrive:cfanalisis-backups

# ── Alerta Telegram (mismo bot que health_check.sh) ──────────────────────
# Bot: @cfanalisis_bot — chat ID del grupo de alertas
TELEGRAM_BOT_TOKEN=<<CAMBIAR>>
TELEGRAM_CHAT_ID=<<CAMBIAR>>
