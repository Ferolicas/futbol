# Supabase Auth (login, sesiones, password reset).
# Las tablas de datos están en el VPS Postgres (ver DATABASE_URL abajo).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# VPS PostgreSQL (todas las tablas de datos: user_profiles, match_*, tickets, …)
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://cfanalisis:PASSWORD@87.106.236.248:5432/cfanalisis
# `false` desactiva SSL (no recomendado en producción). Vacío = SSL relaxed.
DATABASE_SSL=
DATABASE_POOL_MAX=10

# Sanity CMS (legacy — kept for editorial content only)
NEXT_PUBLIC_SANITY_PROJECT_ID=
SANITY_API_TOKEN=
SANITY_DATASET=production

# Football API
FOOTBALL_API_KEY=

# NextAuth (legacy — kept for Stripe URL fallback during migration)
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://cfanalisis.com

# URL publica de la app — usada por API routes para construir URLs absolutas
# (Stripe redirect, webhook callbacks, email links).
NEXT_PUBLIC_APP_URL=https://cfanalisis.com

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COUPON_50_ID=

# Resend (notificaciones internas admin)
RESEND_API_KEY=

# ZeptoMail (emails transaccionales a usuarios: bienvenida, reset contraseña)
# Formato: Zoho-enczapikey {tu_api_key}
ZEPTOMAIL_API_KEY=

# Email
FROM_EMAIL=CFanalisis <onboarding@resend.dev>
ADMIN_EMAIL=ferneyolicas@gmail.com

# ────────────────────────────────────────────────────────────────────────────
# Pusher (DEPRECATED) — el realtime migro a WebSocket nativo via el worker.
# Estas vars siguen aqui solo como referencia historica; los hooks ahora usan
# NEXT_PUBLIC_WORKER_WS_URL + NEXT_PUBLIC_WORKER_SECRET (ver abajo).
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=us2
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=us2
# ────────────────────────────────────────────────────────────────────────────

# Worker en VPS — endpoint /enqueue/* y /broadcast (server-side), y /ws (cliente).
# WORKER_URL: usado por API routes de Next.js para enqueue jobs y emitir eventos.
# En VPS (mismo host), apunta a localhost:8080 para evitar round-trip via Caddy.
# En Vercel (legacy), era https://worker.cfanalisis.com.
WORKER_URL=http://localhost:8080
WORKER_SECRET=
# NEXT_PUBLIC_*: usado por el navegador para conectarse al WebSocket realtime.
NEXT_PUBLIC_WORKER_WS_URL=wss://worker.cfanalisis.com/ws
NEXT_PUBLIC_WORKER_SECRET=  # mismo valor que WORKER_SECRET — viaja al cliente

# ────────────────────────────────────────────────────────────────────────────
# Redis — Modo VPS-local (sin Upstash).
# WORKER_LOCAL_REDIS=true → lib/redis.js usa ioredis TCP a 127.0.0.1:6379
# (mismo Redis local que usa BullMQ). En produccion VPS SIEMPRE true.
# Variables UPSTASH_* ya NO se necesitan — el dual-write a Upstash se elimino
# cuando matamos Vercel en la Fase 4 de la migracion.
# ────────────────────────────────────────────────────────────────────────────
WORKER_LOCAL_REDIS=true
LOCAL_REDIS_HOST=127.0.0.1
LOCAL_REDIS_PORT=6379

# ────────────────────────────────────────────────────────────────────────────
# Error tracking — el worker usa Pino + alertas Telegram con dedup 1/min.
# Las vars TELEGRAM_BOT_TOKEN y TELEGRAM_ALERT_CHAT_ID viven en el .env del
# worker en el VPS, NO aqui. El frontend (Vercel) loguea con console.error,
# Vercel los archiva en su dashboard de logs.
# ────────────────────────────────────────────────────────────────────────────

# The Odds API (https://the-odds-api.com)
THE_ODDS_API_KEY=

# Cron Protection
CRON_SECRET=your-cron-secret-here

# Web Push Notifications (generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
